<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.whlg.hospital.mapper.ConfigMapper">

    <resultMap id="BaseResultMap" type="com.whlg.hospital.entity.Config">
        <id column="id" property="id"/>
        <result column="config_key" property="configKey"/>
        <result column="config_value" property="configValue"/>
        <result column="description" property="description"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, config_key, config_value, description, update_time
    </sql>

    <select id="selectById" resultMap="BaseResultMap" parameterType="java.lang.Long">
        select <include refid="Base_Column_List"/> from t_config where id = #{id}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/> from t_config order by id desc
    </select>

    <insert id="insert" parameterType="com.whlg.hospital.entity.Config" useGeneratedKeys="true" keyProperty="id">
        insert into t_config (
            config_key, config_value, description, update_time
        ) values (
            #{configKey}, #{configValue}, #{description}, #{updateTime}
        )
    </insert>

    <update id="updateById">
        update t_config
        set config_key = #{et.configKey},
            config_value = #{et.configValue},
            description = #{et.description},
            update_time = #{et.updateTime}
        where id = #{et.id}
    </update>

    <delete id="deleteById" parameterType="java.lang.Long">
        delete from t_config where id = #{id}
    </delete>

</mapper>