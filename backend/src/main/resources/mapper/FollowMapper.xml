<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.whlg.hospital.mapper.FollowMapper">

    <resultMap id="BaseResultMap" type="com.whlg.hospital.entity.Follow">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="follow_type" property="followType"/>
        <result column="follow_id" property="followId"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, user_id, follow_type, follow_id, create_time
    </sql>

    <select id="selectById" resultMap="BaseResultMap" parameterType="java.lang.Long">
        select <include refid="Base_Column_List"/> from t_follow where id = #{id}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/> from t_follow order by id desc
    </select>

    <insert id="insert" parameterType="com.whlg.hospital.entity.Follow" useGeneratedKeys="true" keyProperty="id">
        insert into t_follow (
            user_id, follow_type, follow_id, create_time
        ) values (
            #{userId}, #{followType}, #{followId}, #{createTime}
        )
    </insert>

    <update id="updateById">
        update t_follow
        set user_id = #{et.userId},
            follow_type = #{et.followType},
            follow_id = #{et.followId},
            create_time = #{et.createTime}
        where id = #{et.id}
    </update>

    <delete id="deleteById" parameterType="java.lang.Long">
        delete from t_follow where id = #{id}
    </delete>

</mapper>