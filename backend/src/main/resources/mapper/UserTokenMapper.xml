<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.whlg.hospital.mapper.UserTokenMapper">

    <resultMap id="BaseResultMap" type="com.whlg.hospital.entity.UserToken">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="token" property="token"/>
        <result column="status" property="status"/>
        <result column="expire_time" property="expireTime"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, user_id, token, status, expire_time, create_time, update_time
    </sql>

    <select id="selectById" resultMap="BaseResultMap" parameterType="java.lang.Long">
        select <include refid="Base_Column_List"/> from t_user_token where id = #{id}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/> from t_user_token order by id desc
    </select>

    <insert id="insert" parameterType="com.whlg.hospital.entity.UserToken" useGeneratedKeys="true" keyProperty="id">
        insert into t_user_token (
            user_id, token, status, expire_time, create_time, update_time
        ) values (
            #{userId}, #{token}, #{status}, #{expireTime}, #{createTime}, #{updateTime}
        )
    </insert>

    <update id="updateById">
        update t_user_token
        set user_id = #{et.userId},
            token = #{et.token},
            status = #{et.status},
            expire_time = #{et.expireTime},
            create_time = #{et.createTime},
            update_time = #{et.updateTime}
        where id = #{et.id}
    </update>

    <delete id="deleteById" parameterType="java.lang.Long">
        delete from t_user_token where id = #{id}
    </delete>

</mapper>